DATABASE_URL=sqlite:///./sponsorsync.db
LOG_LEVEL=INFO
CLAUDE_MAX_TOKENS_PER_CALL=800
CLAUDE_RUN_BUDGET_USD=1.0
CLAUDE_INPUT_COST_PER_MILLION_TOKENS=3.0
CLAUDE_OUTPUT_COST_PER_MILLION_TOKENS=15.0
REED_API_KEY=your_reed_api_key_here
